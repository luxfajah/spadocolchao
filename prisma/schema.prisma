model CommissionEntry {
  id                 String  @id @default(cuid())
  saleId             String
  sellerId           String
  commissionRuleId   String?
  commissionBatchId  String?
  baseAmount         Float
  percentageApplied  Float?
  fixedAmountApplied Float?
  multiplierApplied  Float   @default(1.0)
  commissionAmount   Float

  goalPercentAtCalculation Float?
  leadSourceAtCalculation  String?
  productAtCalculation     String? // Snapshot of products/categories for audit

  status       String    @default("PENDING") // PENDING, APPROVED, BATCHED, PAID, CANCELLED
  calculatedAt DateTime  @default(now())
  approvedAt   DateTime?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sale            Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  seller          Seller           @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  commissionRule  CommissionRule?  @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)
  commissionBatch CommissionBatch? @relation(fields: [commissionBatchId], references: [id], onDelete: SetNull)

