  foamSupply   SupplyItem? @relation("NewMattressFoam", fields: [foamSupplyItemId], references: [id], onDelete: SetNull)
  tapeSupply   SupplyItem? @relation("NewMattressTape", fields: [tapeSupplyItemId], references: [id], onDelete: SetNull)
  feetSupply   SupplyItem? @relation("NewMattressFeet", fields: [feetSupplyItemId], references: [id], onDelete: SetNull)
}

model SaleItemDetailNewBox {
  id             String @id @default(cuid())
  saleItemId     String @unique
  boxType        String
  commercialSize String
  actualWidth    Float
  actualLength   Float
  actualHeight   Float

  optStructureReinforce  Boolean @default(false)
  optHardwareReplacement Boolean @default(false)

  topFabricSupplyItemId  String?
  topFabricColor         String?
  sideFabricSupplyItemId String?
  sideFabricColor        String?

  feetSupplyItemId String?
  tapeSupplyItemId String?

  technicalNotes String?

  saleItem SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  topFabric  SupplyItem? @relation("NewBoxTopFabric", fields: [topFabricSupplyItemId], references: [id], onDelete: SetNull)
  sideFabric SupplyItem? @relation("NewBoxSideFabric", fields: [sideFabricSupplyItemId], references: [id], onDelete: SetNull)
  feetSupply SupplyItem? @relation("NewBoxFeet", fields: [feetSupplyItemId], references: [id], onDelete: SetNull)
  tapeSupply SupplyItem? @relation("NewBoxTape", fields: [tapeSupplyItemId], references: [id], onDelete: SetNull)
}

model SaleItemDetailUpholsteryCleaning {
  id             String  @id @default(cuid())
  saleItemId     String  @unique
  technicalNotes String?

  saleItem SaleItem                              @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  rows     SaleItemDetailUpholsteryCleaningRow[]
}

model SaleItemDetailUpholsteryCleaningRow {
  id                                 String  @id @default(cuid())
  saleItemDetailUpholsteryCleaningId String
  objectType                         String
  quantity                           Float
  unitPrice                          Float
  subtotal                           Float
  observation                        String?

  cleaningDetail SaleItemDetailUpholsteryCleaning @relation(fields: [saleItemDetailUpholsteryCleaningId], references: [id], onDelete: Cascade)
}

model SupplierSupplyItem {
  id               String   @id @default(cuid())
  supplierId       String
  supplyItemId     String
  supplierItemCode String?
  purchaseUnit     String
  defaultUnitCost  Float
  leadTimeDays     Int
  isPrimary        Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplyItem         SupplyItem          @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([supplierId, supplyItemId])
  @@index([supplierId])
  @@index([supplyItemId])
}

model PurchaseOrder {
  id                   String    @id @default(cuid())
  number               String?   @unique
  supplierId           String
  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?
  status               String    @default("DRAFT") // DRAFT, PENDING, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  subtotalAmount       Float     @default(0)
  discountAmount       Float     @default(0)
  surchargeAmount      Float     @default(0)
  totalAmount          Float     @default(0)
  notes                String?
  createdById          String?
  approvedById         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items           PurchaseOrderItem[]
  receivings      PurchaseReceiving[]
  accountsPayable AccountPayable[]
  createdBy       User?               @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy      User?               @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderItem {
  id                   String   @id @default(cuid())
  purchaseOrderId      String
  supplyItemId         String
  supplierSupplyItemId String?
  quantityOrdered      Float
  quantityReceived     Float    @default(0)
  unit                 String
  unitCost             Float
  totalCost            Float
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  purchaseOrder      PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supplyItem         SupplyItem              @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)
  supplierSupplyItem SupplierSupplyItem?     @relation(fields: [supplierSupplyItemId], references: [id], onDelete: SetNull)
  receivingItems     PurchaseReceivingItem[]

  @@index([purchaseOrderId])
  @@index([supplyItemId])
  @@index([supplierSupplyItemId])
}

model PurchaseReceiving {
  id              String   @id @default(cuid())
  purchaseOrderId String
  receiptDate     DateTime @default(now())
  receivedById    String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  receivedBy    User?                   @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  items         PurchaseReceivingItem[]

  @@index([purchaseOrderId])
}

model PurchaseReceivingItem {
  id                  String   @id @default(cuid())
  purchaseReceivingId String
  purchaseOrderItemId String
  supplyItemId        String
  quantityReceived    Float
  unitCost            Float
  totalCost           Float
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  purchaseReceiving PurchaseReceiving @relation(fields: [purchaseReceivingId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Restrict)
  supplyItem        SupplyItem        @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@index([purchaseReceivingId])
  @@index([purchaseOrderItemId])
  @@index([supplyItemId])
}

model AccountPayable {
  id              String    @id @default(cuid())
  purchaseOrderId String?
  supplierId      String?
  description     String
  dueDate         DateTime
  amount          Float
  paidAmount      Float     @default(0)
  status          String    @default("PENDING") // PENDING, PARTIALLY_PAID, PAID, OVERDUE, RENEGOTIATED, CANCELLED
  issueDate       DateTime  @default(now())
  paymentDate     DateTime?

  financialCategoryId String?
  costCenterId        String?
  financialAccountId  String?
  recurrenceRuleId    String?
  commissionBatchId   String?
  payrollId           String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrder      PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplier           Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  financialCategory  FinancialCategory?  @relation(fields: [financialCategoryId], references: [id], onDelete: SetNull)
  costCenter         CostCenter?         @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  financialAccount   FinancialAccount?   @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  recurrenceRule     RecurrenceRule?     @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  commissionBatch    CommissionBatch?    @relation(fields: [commissionBatchId], references: [id], onDelete: SetNull)
  payroll            Payroll?            @relation(fields: [payrollId], references: [id], onDelete: SetNull)
  paymentAllocations PaymentAllocation[]

  @@index([purchaseOrderId])
  @@index([supplierId])
  @@index([dueDate])
  @@index([status])
  @@index([financialCategoryId])
  @@index([costCenterId])
  @@index([financialAccountId])
}

model FinancialAccount {
  id             String   @id @default(cuid())
  name           String
  type           String // CASH, BANK, PIX, SAVINGS, CREDIT_CARD
  bankName       String?
  agency         String?
  accountNumber  String?
  pixKey         String?
  initialBalance Float    @default(0)
  currentBalance Float    @default(0)
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE, CLOSED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions       FinancialTransaction[]
  transfersFrom      TransferRecord[]       @relation("TransferFrom")
  transfersTo        TransferRecord[]       @relation("TransferTo")
  accountsPayable    AccountPayable[]
  accountsReceivable AccountReceivable[]
}

model AccountReceivable {
  id                String    @id @default(cuid())
  saleId            String?
  saleInstallmentId String?   @unique
  customerId        String?
  description       String
  dueDate           DateTime
  amount            Float
  paidAmount        Float     @default(0)
  status            String    @default("PENDING") // PENDING, PARTIALLY_RECEIVED, RECEIVED, OVERDUE, RENEGOTIATED, CANCELLED
  issueDate         DateTime  @default(now())
  receivedDate      DateTime?

  financialCategoryId String?
  costCenterId        String?
  financialAccountId  String?
  recurrenceRuleId    String?
  paymentMethodId     String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale               Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)
  saleInstallment    SaleInstallment?    @relation(fields: [saleInstallmentId], references: [id], onDelete: SetNull)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  financialCategory  FinancialCategory?  @relation(fields: [financialCategoryId], references: [id], onDelete: SetNull)
  costCenter         CostCenter?         @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  financialAccount   FinancialAccount?   @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  recurrenceRule     RecurrenceRule?     @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  paymentMethod      PaymentMethod?      @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentAllocations PaymentAllocation[]

  @@index([saleId])
  @@index([customerId])
  @@index([dueDate])
  @@index([status])
  @@index([financialCategoryId])
  @@index([costCenterId])
  @@index([financialAccountId])
}

model FinancialTransaction {
  id              String   @id @default(cuid())
  type            String // ENTRY (Credit), EXIT (Debit)
  amount          Float
  transactionDate DateTime @default(now())
  description     String
  status          String   @default("CONFIRMED") // PENDING, CONFIRMED, CANCELLED

  financialAccountId  String
  financialCategoryId String?
  performedById       String?

  // Links to titles/operations
  isTransfer Boolean @default(false)
  transferId String?

  cashRegisterSessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financialAccount  FinancialAccount   @relation(fields: [financialAccountId], references: [id], onDelete: Restrict)
  financialCategory FinancialCategory? @relation(fields: [financialCategoryId], references: [id], onDelete: SetNull)
  performedBy       User?              @relation(fields: [performedById], references: [id], onDelete: SetNull)

  transfer            TransferRecord?      @relation(fields: [transferId], references: [id], onDelete: SetNull)
  cashRegisterSession CashRegisterSession? @relation(fields: [cashRegisterSessionId], references: [id], onDelete: SetNull)

  cashRegisterMovements CashRegisterMovement[]
  paymentAllocations    PaymentAllocation[]
  reconciliation        FinancialReconciliation?

  @@index([financialAccountId])
  @@index([financialCategoryId])
  @@index([transactionDate])
  @@index([type])
  @@index([status])
}

model PaymentAllocation {
  id                  String   @id @default(cuid())
  transactionId       String
  accountReceivableId String?
  accountPayableId    String?
  amountAllocated     Float
  createdAt           DateTime @default(now())

  transaction       FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountReceivable AccountReceivable?   @relation(fields: [accountReceivableId], references: [id], onDelete: SetNull)
  accountPayable    AccountPayable?      @relation(fields: [accountPayableId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([accountReceivableId])
  @@index([accountPayableId])
}

model TransferRecord {
  id            String   @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amount        Float
  transferDate  DateTime @default(now())
  description   String?
  performedById String?
  createdAt     DateTime @default(now())

  fromAccount FinancialAccount @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount   FinancialAccount @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)
  performedBy User?            @relation("TransferPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)

  transactions FinancialTransaction[]

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([transferDate])
}

model RecurrenceRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String // RECEIVABLE, PAYABLE
  frequency   String // DAILY, WEEKLY, MONTHLY, YEARLY
  interval    Int       @default(1)
  dayOfMonth  Int?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)

  baseAmount          Float
  financialCategoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financialCategory  FinancialCategory?  @relation(fields: [financialCategoryId], references: [id], onDelete: SetNull)
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]

  @@index([type])
  @@index([isActive])
}

model FinancialReconciliation {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  bankStatementId String?
  status          String   @default("CONCILIATED") // CONCILIATED, DIVERGENT
  notes           String?
  conciliatedById String?
  conciliatedAt   DateTime @default(now())

  transaction   FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  conciliatedBy User?                @relation(fields: [conciliatedById], references: [id], onDelete: SetNull)

  @@index([transactionId])
}

model OrderNote {
  id          String   @id @default(cuid())
  orderId     String
  type        String   @default("OBSERVATION") // INTERNAL, CUSTOMER, DELIVERY, PRODUCTION
  content     String
  createdById String?
  createdAt   DateTime @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdById])
}

model OrderDelivery {
  id             String    @id @default(cuid())
  orderId        String
  status         String    @default("PENDING") // PENDING, ON_THE_WAY, DELIVERED, FAILED, CANCELLED
  scheduledDate  DateTime?
  deliveredAt    DateTime?
  recipientName  String?
  recipientPhone String?

  // Endereço específico para esta entrega (pode ser diferente do pedido original)
  zipCode      String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderProductionSlip {
  id          String   @id @default(cuid())
  orderId     String
  number      String?  @unique
  status      String   @default("DRAFT") // DRAFT, ISSUED, COMPLETED, CANCELLED
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order     Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User?                     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines     OrderProductionSlipLine[]

  @@index([orderId])
  @@index([createdById])
}

model OrderProductionSlipLine {
  id               String  @id @default(cuid())
  productionSlipId String
  saleItemId       String
  quantity         Float
  notes            String?

  productionSlip OrderProductionSlip @relation(fields: [productionSlipId], references: [id], onDelete: Cascade)
  saleItem       SaleItem            @relation(fields: [saleItemId], references: [id], onDelete: Restrict)

  @@index([productionSlipId])
  @@index([saleItemId])
}

// -----------------------------------------------------------------------------
// HR MODULE MODELS
// -----------------------------------------------------------------------------

model EmployeeDocument {
  id          String    @id @default(cuid())
  employeeId  String
  type        String // CONTRACT, ADDENDUM, WARNING, SUSPENSION, LETTER, TERM, DECLARATION, REGISTRATION_FORM, RESUME, OTHER
  name        String
  description String?
  fileUrl     String
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeNote {
  id          String   @id @default(cuid())
  employeeId  String
  content     String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("EmployeeNoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([createdById])
}

model EmployeeVacation {
  id          String    @id @default(cuid())
  employeeId  String
  periodStart DateTime
  periodEnd   DateTime
  days        Int
  status      String    @default("SCHEDULED") // SCHEDULED, TAKEN, CANCELLED
  returnDate  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model JobOpening {
  id            String    @id @default(cuid())
  title         String
  department    String?
  role          String?
  jobTitleId    String?
  contractType  String // CLT, PJ, INTERNSHIP, TEMPORARY
  salaryRange   String?
  location      String?
  workModel     String // ONSITE, HYBRID, REMOTE
  description   String
  requirements  String?
  benefits      String? // JSON or long text
  responsibleId String?
  status        String    @default("DRAFT") // DRAFT, OPEN, SCREENING, INTERVIEWS, OFFER, CLOSED, CANCELLED
  openingDate   DateTime?
  closingDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  jobTitle     JobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  applications CandidateApplication[]
  interviews   InterviewSchedule[]

  @@index([status])
  @@index([jobTitleId])
}

model Candidate {
  id                 String   @id @default(cuid())
  fullName           String
  socialName         String?
  phone              String?
  whatsapp           String?
  email              String?
  city               String?
  state              String?
  resumeUrl          String?
  portfolioUrl       String?
  linkedinUrl        String?
  positionOfInterest String?
  salaryExpectation  Float?
  availability       String?
  source             String? // INDICATION, LINKEDIN, SITE, OTHER
  notes              String?
  status             String   @default("NEW") // NEW, SCREENING, SHORTLISTED, INTERVIEW_SCHEDULED, INTERVIEWED, APPROVED, REJECTED, TALENT_POOL, HIRED, ARCHIVED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  applications CandidateApplication[]
  interviews   InterviewSchedule[]
  talentPool   TalentPoolEntry?
  tags         CandidateTag[]         @relation("CandidateToTag")
}

model CandidateTag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  candidates Candidate[] @relation("CandidateToTag")
}

model CandidateApplication {
  id              String   @id @default(cuid())
  candidateId     String
  jobOpeningId    String
  applicationDate DateTime @default(now())
  status          String   @default("SCREENING") // SCREENING, SHORTLISTED, INTERVIEWING, REJECTED, OFFERED, HIRED
  notes           String?

  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobOpeningId])
  @@index([jobOpeningId])
}

model InterviewSchedule {
  id             String   @id @default(cuid())
  candidateId    String
  jobOpeningId   String?
  interviewerId  String?
  stage          String // SCREENING, INITIAL, TECHNICAL, FINAL, ALIGNMENT, FEEDBACK
  scheduledDate  DateTime
  startTime      DateTime
  endTime        DateTime
  locationOrLink String?
  notes          String?
  status         String   @default("SCHEDULED") // SCHEDULED, CONFIRMED, COMPLETED, RESCHEDULED, CANCELLED, NO_SHOW, CLOSED
  result         String? // JSON or text with evaluation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOpening  JobOpening? @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)
  interviewer Employee?   @relation("InterviewInterviewer", fields: [interviewerId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@index([jobOpeningId])
  @@index([interviewerId])
  @@index([scheduledDate])
}

model TalentPoolEntry {
  id              String   @id @default(cuid())
  candidateId     String   @unique
  area            String?
  jobTitle        String?
  experienceLevel String?
  notes           String?
  priority        Boolean  @default(false)
  lastInteraction DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model DisciplinaryAction {
  id                String   @id @default(cuid())
  employeeId        String
  type              String // VERBAL_WARNING, WRITTEN_WARNING, SUSPENSION
  incidentDate      DateTime
  applicationDate   DateTime
  reason            String
  description       String?
  witnesses         String? // Name or JSON
  responsibleId     String?
  attachmentUrl     String? // URL or local path to signed document / scan
  employeeAwareness Boolean  @default(false)
  status            String   @default("DRAFT") // DRAFT, APPLIED, SIGNED, REFUSED, CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  responsible User?    @relation("DisciplinaryActionResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([responsibleId])
}

model TerminationProcess {
  id              String    @id @default(cuid())
  employeeId      String    @unique
  type            String // RESIGNATION, DISMISSAL_WITHOUT_CAUSE, DISMISSAL_WITH_CAUSE, END_OF_CONTRACT, PROBATION_PERIOD, MUTUAL_AGREEMENT
  noticeDate      DateTime?
  terminationDate DateTime
  reason          String?
  notes           String?
  attachmentUrl   String? // URL or local path to resignation letter / termination docs
  responsibleId   String?
  status          String    @default("STARTED") // STARTED, CALCULATING, WAITING_DOCUMENTS, WAITING_PAYMENT, COMPLETED, CANCELLED

  // Checklist (boolean JSON or flags)
  itemsReturned   Boolean @default(false)
  accessRevoked   Boolean @default(false)
  docsCompleted   Boolean @default(false)
  resignationCalc Boolean @default(false)
  financialSent   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  responsible User?    @relation("TerminationResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  @@index([responsibleId])
}

// ─── Relógio de Ponto — Importação AFD ────────────────────────────────────────

model PunchImportBatch {
  id           String   @id @default(cuid())
  fileName     String
  period       String   // "YYYY-MM"
  totalRecords Int      @default(0)
  importedBy   String?  // userId
  notes        String?
  createdAt    DateTime @default(now())

  records PunchRecord[]
}

model PunchRecord {
  id          String   @id @default(cuid())
  batchId     String
  employeeId  String?  // null if PIS/matrícula não encontrada no sistema
  pis         String?  // PIS/PASEP ou matrícula do relógio
  employeeName String? // nome extraído do arquivo se disponível
  punchDate   DateTime // data e hora exata da batida
  punchType   String   // IN | OUT | UNKNOWN
  source      String   @default("AFD") // AFD | AFDT | MANUAL | CSV
  createdAt   DateTime @default(now())

  batch    PunchImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  employee Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([employeeId])
  @@index([punchDate])
}

// ─── Novas Batidas (Sistema de Ponto Avançado) ──────────────────────────────

model TimePunchImport {
  id           String      @id @default(cuid())
  fileName     String
  importedAt   DateTime    @default(now())
  status       String      @default("COMPLETED")
  recordsCount Int         @default(0)
  punches      TimePunch[]
}

model TimePunch {
  id              String           @id @default(cuid())
  importId        String
  employeeId      String?
  enNo            String
  punchDateTime   DateTime
  type            String          // CLOCK_IN, CLOCK_OUT, etc.
  rawType         String          // S, E, A, F, I, O
  isNormalized    Boolean          @default(false)
  normalizedFromId String?
  createdAt       DateTime         @default(now())

  import          TimePunchImport  @relation(fields: [importId], references: [id], onDelete: Cascade)
  employee        Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([importId])
  @@index([employeeId])
  @@index([punchDateTime])
}

model AttendanceDay {
  id              String   @id @default(cuid())
  employeeId      String
  date            DateTime // Somente data (00:00:00)
  expectedMinutes Int
  workedMinutes   Int
  overtimeMinutes Int
  deficitMinutes  Int
  firstIn         DateTime?
  lunchOut        DateTime?
  lunchIn         DateTime?
  lastOut         DateTime?
  originalFirstIn DateTime?
  originalLunchOut DateTime?
  originalLunchIn DateTime?
  originalLastOut DateTime?
  isManualAdjustment Boolean   @default(false)
  status          String
  anomalies       String? // Texto formatado ou JSON
  adjustmentType  String? // ABONO, ATESTADO_MEDICO, ATESTADO_HORARIO, FERIADO, FOLGA_PREMIO
  adjustmentReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mirrorId        String?

  employee        Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  mirror          AttendanceMirror? @relation(fields: [mirrorId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([mirrorId])
}

model AttendanceMirror {
  id              String   @id @default(cuid())
  employeeId      String
  period          String // "2026-03" ou custom label
  startDate       DateTime
  endDate         DateTime
  expectedMinutes Int      @default(0)
  workedMinutes   Int      @default(0)
  overtimeMinutes Int      @default(0)
  deficitMinutes  Int      @default(0)
  status          String   @default("GENERATED") // GENERATED, EDITING, ADJUSTED, APPROVED
  summary         String?  // JSON com contagens (faltas, etc)
  finalizedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime?

  employee Employee        @relation(fields: [employeeId], references: [id])
  days     AttendanceDay[]
  payrolls Payroll[]

  @@index([employeeId, period])
}

// ─── Feriados Configuráveis ─────────────────────────────────────────────────

model CompanyHoliday {
  id              String   @id @default(cuid())
  date            DateTime // Data exata do feriado (YYYY-MM-DD 00:00:00 UTC)
  name            String
  type            String   @default("NATIONAL") // NATIONAL, STATE, MUNICIPAL, MOVEABLE, CUSTOM
  closesCommerce  Boolean  @default(true)       // Se true, abona automaticamente
  isRecurring     Boolean  @default(false)       // Se true, repete todo ano (fixo)
  recurringDay    Int?                           // Dia do mês para recorrência
  recurringMonth  Int?                           // Mês para recorrência (1-12)
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, name])
  @@index([date])
  @@index([type])
}
