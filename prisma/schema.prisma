generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String?   @unique
  socialName   String?
  phone        String?
  username     String    @unique
  passwordHash String
  status       String    @default("ACTIVE")
  isSuperAdmin Boolean   @default(false)
  jobTitle     String?
  department   String?
  notes        String?
  employeeId   String?   @unique
  primaryRoleId String?
  mustChangePassword Boolean @default(false)
  passwordChangedAt  DateTime?
  passwordExpiresAt  DateTime?
  failedLoginAttempts Int    @default(0)
  blockedAt          DateTime?
  blockedReason      String?
  lastLoginAt  DateTime?
  lastLoginIp  String?
  lastLoginUserAgent String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee            Employee?                 @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  primaryRole         Role?                     @relation("PrimaryRoleUsers", fields: [primaryRoleId], references: [id], onDelete: SetNull)
  roles               UserRole[]
  sessions            UserSession[]
  permissionOverrides UserPermissionOverride[]
  auditLogs           AuditLog[]
  changedSettings     SystemSettingHistory[]    @relation("SystemSettingChangedBy")
  attachments         FileAttachment[]
  orderStatusHistory  OrderStatusHistory[]
  openedCashRegisters CashRegisterSession[]  @relation("SessionOpenedBy")
  closedCashRegisters CashRegisterSession[]  @relation("SessionClosedBy")
  cashMovements       CashRegisterMovement[]

  financialTransactions FinancialTransaction[]
  reconciliations       FinancialReconciliation[]
  transfersPerformed    TransferRecord[]          @relation("TransferPerformedBy")

  createdPurchaseOrders  PurchaseOrder[]     @relation("PurchaseOrderCreatedBy")
  approvedPurchaseOrders PurchaseOrder[]     @relation("PurchaseOrderApprovedBy")
  purchaseReceivings     PurchaseReceiving[]

  customerNotes         CustomerNote[]          @relation("NoteCreatedBy")
  customerCreditChanges CustomerCreditHistory[] @relation("CreditLimitChangedBy")

  cancelledSales       Sale[]                @relation("SaleCancelledBy")
  cancelledOrders      Order[]               @relation("OrderCancelledBy")
  orderNotes           OrderNote[]
  orderProductionSlips OrderProductionSlip[]

  // HR Module
  createdEmployeeNotes           EmployeeNote[]       @relation("EmployeeNoteCreatedBy")
  disciplinaryActionsResponsible DisciplinaryAction[] @relation("DisciplinaryActionResponsible")
  terminationsResponsible        TerminationProcess[] @relation("TerminationResponsible")

  createdBackups  BackupRecord[] @relation("BackupCreatedBy")
  restoredBackups BackupRecord[] @relation("BackupRestoredBy")

  @@index([employeeId])
  @@index([primaryRoleId])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  status      String   @default("ACTIVE")
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]
  primaryUsers User[] @relation("PrimaryRoleUsers")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  module      String
  action      String?
  description String?
  status      String   @default("ACTIVE")
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles             RolePermission[]
  userOverrides     UserPermissionOverride[]
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  module    String   @default("GENERAL")
  action    String
  entity    String // NEW: Consistent with actions.ts
  entityId  String?
  description String?
  details   String? // NEW: Consistent with actions.ts
  origin    String   @default("WEB")
  oldData   String?
  newData   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  session UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId])
  @@index([sessionId])
  @@index([module])
  @@index([ipAddress])
  @@index([createdAt])
}

model SaleItemMaterialRequirement {
  id                 String  @id @default(cuid())
  saleItemId         String
  sourceRecipeId     String?
  sourceRecipeItemId String?
  supplyItemId       String

  part               String
  quantityCalculated Float
  unit               String
  unitCostSnapshot   Float
  totalCostSnapshot  Float
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  supplyItem SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Restrict)

  @@index([saleItemId])
  @@index([supplyItemId])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyProfile {
  id                    String   @id @default(cuid())
  legalName             String
  tradeName             String?
  cnpj                  String?  @unique
  stateRegistration     String?
  municipalRegistration String?
  zipCode               String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  phone                 String?
  whatsapp              String?
  email                 String?
  website               String?
  logoUrl               String?
  legalRepresentative   String?
  printName             String?
  printDocument         String?
  printAddress          String?
  printPhone            String?
  printFooter           String?
  operationalEmail      String?
  operationalHours      String?
  operationalNotes      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UserPermissionOverride {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  effect       String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@index([effect])
}

model UserSession {
  id             String   @id @default(cuid())
  userId         String
  sessionToken   String   @unique
  ipAddress      String?
  userAgent      String?
  startedAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  expiresAt      DateTime?
  endedAt        DateTime?
  endReason      String?
  isActive       Boolean  @default(true)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  @@index([userId, isActive])
  @@index([lastActivityAt])
}

model SystemSetting {
  id          String   @id @default(cuid())
  group       String
  key         String   @unique
  label       String
  value       String
  valueType   String   @default("string")
  description String?
  category    String?
  isSecret    Boolean  @default(false)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  history SystemSettingHistory[]

  @@index([group])
  @@index([category])
}

model SystemSettingHistory {
  id            String   @id @default(cuid())
  settingId     String
  previousValue String?
  newValue      String?
  changedById   String?
  note          String?
  changedAt     DateTime @default(now())

  setting   SystemSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  changedBy User?         @relation("SystemSettingChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([settingId])
  @@index([changedById])
  @@index([changedAt])
}

model DocumentSequence {
  id         String   @id @default(cuid())
  type       String   @unique
  name       String
  prefix     String?
  nextNumber Int      @default(1)
  digits     Int      @default(6)
  resetMode  String   @default("NEVER")
  status     String   @default("ACTIVE")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PrinterProfile {
  id               String   @id @default(cuid())
  name             String   @unique
  type             String
  driverName       String?
  paperWidth       String?
  isDefault        Boolean  @default(false)
  autoPrint        Boolean  @default(false)
  headerTemplate   String?
  footerTemplate   String?
  documentTemplate String?
  notes            String?
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([type])
  @@index([status])
}

model SystemAutomation {
  id                   String   @id @default(cuid())
  code                 String   @unique
  name                 String
  category             String
  description          String?
  isEnabled            Boolean  @default(true)
  frequency            String?
  notificationChannels String?
  config               String?
  lastRunAt            DateTime?
  nextRunAt            DateTime?
  lastResult           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([category])
  @@index([isEnabled])
}

model BackupRecord {
  id           String   @id @default(cuid())
  label        String?
  filePath     String
  fileName     String
  backupType   String   @default("MANUAL")
  status       String   @default("COMPLETED")
  sizeBytes    Int?
  notes        String?
  createdById  String?
  restoredById String?
  createdAt    DateTime @default(now())
  restoredAt   DateTime?

  createdBy  User? @relation("BackupCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  restoredBy User? @relation("BackupRestoredBy", fields: [restoredById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([backupType])
  @@index([status])
}

model FileAttachment {
  id           String   @id @default(cuid())
  originalName String
  storedName   String
  mimeType     String
  extension    String?
  filePath     String
  fileSize     Int
  entityName   String?
  entityId     String?
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([entityName, entityId])
  @@index([uploadedById])
}

model CostCenter {
  id                 String              @id @default(cuid())
  code               String              @unique
  name               String
  description        String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Employee           Employee[]
  jobTitles          JobTitle[]
  financialCategories FinancialCategory[]
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]
}

model PaymentMethod {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  type               String
  allowsInstallments Boolean  @default(false)
  maxInstallments    Int?
  feePercentage      Float    @default(0)
  fixedFee           Float    @default(0)
  settlementDays     Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  saleInstallments   SaleInstallment[]
  cashMovements      CashRegisterMovement[]
  accountsReceivable AccountReceivable[]
  installmentFees    PaymentMethodInstallmentFee[]
}

model PaymentMethodInstallmentFee {
  id              String        @id @default(cuid())
  paymentMethodId String
  installments    Int
  feePercentage   Float
  
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, installments])
  @@index([paymentMethodId])
}

model FinancialCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  costCenters        CostCenter[]
  accountsReceivable AccountReceivable[]
  accountsPayable    AccountPayable[]
  transactions       FinancialTransaction[]
  recurrenceRules    RecurrenceRule[]
}

model LeadSource {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String  @unique
  category    String  @default("OUTRO") // Digital paga, Digital orgânica, Loja física, Indicação, Campanha, Externa, Parceria, Reativação, Outro
  description String?
  isActive    Boolean @default(true)

  // Regras Comerciais
  isDefaultPdv          Boolean @default(false)
  requiresDetail        Boolean @default(false)
  commissionEligible    Boolean @default(true)
  hasCommissionOverride Boolean @default(false)
  priority              Int     @default(0)

  // Rastreamento / Análise
  estimatedCost Float   @default(0)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
  customers Customer[]
  storeGoalSegments StoreGoalSegment[]
}

model JobTitle {
  id                String        @id @default(cuid())
  name              String        @unique
  department        String?
  description       String?
  shiftName         String?
  defaultSalary     Float?
  workScheduleId    String?
  costCenterId      String?
  cbo               String?
  isPdvSellerRole   Boolean       @default(false)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  workSchedule      WorkSchedule? @relation("JobTitleDefaultSchedule", fields: [workScheduleId], references: [id], onDelete: SetNull)
  costCenter        CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  employees         Employee[]
  jobOpenings       JobOpening[]

  @@index([workScheduleId])
  @@index([costCenterId])
}

model WorkSchedule {
  id                   String   @id @default(cuid())
  name                 String   @unique
  weeklyHours          Float
  mondayMinutes        Int      @default(0)
  tuesdayMinutes       Int      @default(0)
  wednesdayMinutes     Int      @default(0)
  thursdayMinutes      Int      @default(0)
  fridayMinutes        Int      @default(0)
  saturdayMinutes      Int      @default(0)
  sundayMinutes        Int      @default(0)
  expectedLunchMinutes Int      @default(0)
  toleranceMinutes     Int      @default(5)
  mondayIn1            String?
  mondayOut1           String?
  mondayIn2            String?
  mondayOut2           String?
  tuesdayIn1           String?
  tuesdayOut1          String?
  tuesdayIn2           String?
  tuesdayOut2          String?
  wednesdayIn1         String?
  wednesdayOut1        String?
  wednesdayIn2         String?
  wednesdayOut2        String?
  thursdayIn1          String?
  thursdayOut1         String?
  thursdayIn2          String?
  thursdayOut2         String?
  fridayIn1            String?
  fridayOut1           String?
  fridayIn2            String?
  fridayOut2           String?
  saturdayIn1          String?
  saturdayOut1         String?
  saturdayIn2          String?
  saturdayOut2         String?
  sundayIn1            String?
  sundayOut1           String?
  sundayIn2            String?
  sundayOut2           String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  employees Employee[]
  jobTitles JobTitle[] @relation("JobTitleDefaultSchedule")
}

model Customer {
  id                String    @id @default(cuid())
  code              String?   @unique
  personType        String    @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  fullName          String
  tradeName         String?
  document          String?
  stateRegistration String?
  rg                String?
  birthDate         DateTime?
  gender            String?
  profession        String?
  income            Float?
  email             String?
  phone             String?
  whatsapp          String?
  instagram         String?
  contactPerson     String?
  notes             String?
  customerSince     DateTime  @default(now())
  isActive          Boolean   @default(true)

  // Dados de Vendas / CRM
  sellerId         String?
  leadSourceId     String?
  creditLimit      Float?  @default(0)
  priority         String? @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  commercialStatus String? @default("ACTIVE") // ACTIVE, INACTIVE, PROSPECT, BLOCKED
  invoiceEmail     String?
  motherName       String?
  fatherName       String?
  companySize      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  seller     Seller?     @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  leadSource LeadSource? @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)

  addresses     CustomerAddress[]
  contacts      CustomerContact[]
  noteHistory   CustomerNote[]
  creditHistory CustomerCreditHistory[]

  sales              Sale[]
  orders             Order[]
  accountsReceivable AccountReceivable[]

  @@index([fullName])
  @@index([document])
  @@index([sellerId])
  @@index([leadSourceId])
}

model CustomerAddress {
  id             String  @id @default(cuid())
  customerId     String
  type           String  @default("MAIN") // MAIN, DELIVERY, BILLING
  zipCode        String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  recipientName  String?
  recipientPhone String?
  isMain         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerContact {
  id         String  @id @default(cuid())
  customerId String
  name       String
  relation   String?
  phone      String?
  whatsapp   String?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerNote {
  id          String   @id @default(cuid())
  customerId  String
  noteType    String   @default("OBSERVATION") // COMMERCIAL, FINANCIAL, DELIVERY, SUPPORT, OBSERVATION
  content     String
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("NoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([createdById])
}

model CustomerCreditHistory {
  id            String   @id @default(cuid())
  customerId    String
  previousLimit Float?
  newLimit      Float?
  reason        String?
  changedById   String?
  createdAt     DateTime @default(now())

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  changedBy User?    @relation("CreditLimitChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([changedById])
}

model Supplier {
  id                String   @id @default(cuid())
  code              String?  @unique
  personType        String   @default("COMPANY")
  legalName         String
  tradeName         String?
  document          String?  @unique
  stateRegistration String?
  email             String?
  phone             String?
  whatsapp          String?
  contactPerson     String?
  zipCode           String?
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  supplyItems         SupplyItem[]
  products            ProductService[]     @relation("ProductSupplier")
  supplierSupplyItems SupplierSupplyItem[]
  purchaseOrders      PurchaseOrder[]
  accountsPayable     AccountPayable[]

  @@index([legalName])
  @@index([tradeName])
  @@index([city, state])
}

model Seller {
  id                    String   @id @default(cuid())
  code                  String?  @unique
  name                  String
  type                  String   @default("INTERNAL")
  document              String?  @unique
  email                 String?
  phone                 String?
  whatsapp              String?
  defaultCommissionRate Float?
  employeeId            String?  @unique
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employee          Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  sales             Sale[]
  orders            Order[]
  commissionEntries CommissionEntry[]
  commissionBatches CommissionBatch[]
  goals             SellerGoal[]
  customers         Customer[]

  @@index([name])
  @@index([employeeId])
}

model Employee {
  id                      String    @id @default(cuid())
  serialId                Int?      @unique
  code                    String?   @unique
  fullName                String
  socialName              String?
  cpf                     String?   @unique
  rg                      String?
  rgExpeditor             String?
  rgIssuanceDate          DateTime?
  pis                     String?
  birthDate               DateTime?
  birthCity               String?
  birthState              String?
  gender                  String?
  maritalStatus           String?
  educationLevel          String?
  nationality             String?
  raceColor               String?
  voterCardNumber         String?
  voterCardZone           String?
  voterCardSection        String?
  professionalCouncilNumber String?
  professionalCouncilName String?
  ctpsNumber              String?
  ctpsSeries              String?
  ctpsIssuanceDate        DateTime?
  ctpsUf                  String?
  cnhNumber               String?
  cnhCategory             String?
  militaryDocumentNumber  String?
  militaryDocumentCategory String?
  email                   String?
  phone                   String?
  whatsapp                String?
  zipCode                 String?
  address                 String?
  street                  String?
  number                  String?
  complement              String?
  neighborhood            String?
  city                    String?
  state                   String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  motherName              String?
  fatherName              String?
  photoUrl                String?
  isPCD                   Boolean   @default(false)
  pcdDetails              String?
  hasHealthCondition      Boolean   @default(false)
  healthConditionDetails  String?
  schoolName              String?
  schoolShift             String?
  technicalCourse         String?
  apprenticeshipEnd       DateTime?
  admissionDate           DateTime?
  terminationDate         DateTime?
  status                  String    @default("ACTIVE")
  contractType            String
  department              String?
  workScheduleText        String?
  salaryBase              Float?
  vtDailyValue            Float?
  vtWorkDaysPerMonth      Int?
  transportationAllowance Float?
  transportationPayrollDeductionEnabled Boolean @default(false)
  transportationPayrollDeductionPercent Float?
  foodAllowance           Float?
  foodPayrollDeductionEnabled Boolean @default(false)
  foodPayrollDeductionPercent Float?
  fuelAllowance           Float?
  healthPlan              Boolean   @default(false)
  healthPlanDetails       String?
  dentalPlan              Boolean   @default(false)
  lifeInsurance           Boolean   @default(false)
  attendanceBonusEnabled  Boolean   @default(false)
  attendanceBonusAmount   Float?
  attendanceBonus         Float?
  pharmacyAllowance       Float?
  childcareAllowance      Float?
  otherBenefits           String?
  fgtsOptionDate          DateTime?
  fgtsAccount             String?
  fgtsRectificationDate   DateTime?
  benefits                String?
  bankName                String?
  bankBranch              String?
  bankAccount             String?
  bankAccountType         String?
  pixKey                  String?
  pixKeyType              String?
  notes                   String?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  jobTitleId     String?
  workScheduleId String?
  costCenterId   String?

  jobTitle     JobTitle?     @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  workSchedule WorkSchedule? @relation(fields: [workScheduleId], references: [id], onDelete: SetNull)
  costCenter   CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  systemUser   User?
  sellerProfile Seller?
  payrolls     Payroll[]

  pointMachineId String? @unique

  documents           EmployeeDocument[]
  notesHistory        EmployeeNote[]
  vacations           EmployeeVacation[]
  interviews          InterviewSchedule[]  @relation("InterviewInterviewer")
  disciplinaryActions DisciplinaryAction[]
  terminations        TerminationProcess[]
  punchRecords        PunchRecord[]
  timePunches         TimePunch[]
  attendanceDays      AttendanceDay[]
  attendanceMirrors   AttendanceMirror[]

  @@index([fullName])
  @@index([status])
  @@index([jobTitleId])
  @@index([workScheduleId])
  @@index([costCenterId])
}

model ProductService {
  id                    String   @id @default(cuid())
  code                  String?  @unique
  name                  String
  type                  String   @default("SERVICE") // Serviço, Produto final, Insumo, Tecido, Espuma, Estrutura / ferragem, Item de limpeza
  description           String?
  unit                  String?
  defaultPrice          Float?
  defaultCost           Float?
  productionTimeMinutes Int?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Aba 1. Identificação
  operationalCategory String? // Reforma de colchão, Reforma de box, Colchão novo, Box novo, Limpeza de estofados...
  internalNotes       String?

  // Aba 2. Comercial
  minimumPrice                    Float?
  allowPriceChangeInPDV           Boolean @default(false)
  requirePriceChangeJustification Boolean @default(false)
  defaultCommission               Float?
  averageLeadTime                 Int?
  highlightInPDV                  Boolean @default(false)
  catalogOrder                    Int     @default(0)

  // Aba 3. Configuração operacional
  operationalConfig String? // JSON string contendo as opções específicas da categoria

  // Aba 4. Ficha técnica / consumo
  useTechnicalSheet        Boolean @default(false)
  consumesStock            Boolean @default(false)
  generatesProductionOrder Boolean @default(false)
  estimatedLaborCost       Float?
  wastePercentage          Float   @default(0)

  // Aba 5. Estoque e compras
  managesStock      Boolean @default(false)
  minimumStock      Float   @default(0)
  currentStock      Float   @default(0)
  primarySupplierId String?
  lastCost          Float?
  stockLocation     String?
  purchaseLeadTime  Int?

  // Aba 6. Fiscal
  ncm       String?
  cest      String?
  cfop      String?
  taxOrigin String?
  taxNotes  String?
  imageUrl  String?

  primarySupplier Supplier? @relation("ProductSupplier", fields: [primarySupplierId], references: [id], onDelete: SetNull)

  saleItems SaleItem[]
  recipes   ProductRecipe[]

  @@index([name])
  @@index([type])
  @@index([operationalCategory])
  @@index([primarySupplierId])
}

model SupplyCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplyItems SupplyItem[]
}

model SupplyItem {
  id               String   @id @default(cuid())
  code             String?  @unique
  name             String
  description      String?
  unit             String
  currentStock     Float    @default(0)
  minimumStock     Float    @default(0)
  averageCost      Float    @default(0)
  lastPurchaseCost Float?
  location         String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categoryId        String?
  primarySupplierId String?
  imageUrl          String?

  category               SupplyCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  primarySupplier        Supplier?               @relation(fields: [primarySupplierId], references: [id], onDelete: SetNull)
  stockMovements         StockMovement[]
  recipeItems            ProductRecipeItem[]
  supplierSupplyItems    SupplierSupplyItem[]
  purchaseOrderItems     PurchaseOrderItem[]
  purchaseReceivingItems PurchaseReceivingItem[]

  mattressTopFabrics       SaleItemDetailMattressReform[] @relation("MattressTopFabric")
  mattressBottomFabrics    SaleItemDetailMattressReform[] @relation("MattressBottomFabric")
  mattressSideFabrics      SaleItemDetailMattressReform[] @relation("MattressSideFabric")
  boxTopFabrics            SaleItemDetailBoxReform[]      @relation("BoxTopFabric")
  boxSideFabrics           SaleItemDetailBoxReform[]      @relation("BoxSideFabric")
  newMattressTopFabrics    SaleItemDetailNewMattress[]    @relation("NewMattressTopFabric")
  newMattressBottomFabrics SaleItemDetailNewMattress[]    @relation("NewMattressBottomFabric")
  newMattressSideFabrics   SaleItemDetailNewMattress[]    @relation("NewMattressSideFabric")
  newBoxTopFabrics         SaleItemDetailNewBox[]         @relation("NewBoxTopFabric")
  newBoxSideFabrics        SaleItemDetailNewBox[]         @relation("NewBoxSideFabric")

  saleItemMaterialRequirements SaleItemMaterialRequirement[]

  mattressFoamSupply SaleItemDetailMattressReform[] @relation("MattressFoam")
  mattressTapeSupply SaleItemDetailMattressReform[] @relation("MattressTape")
  mattressFeetSupply SaleItemDetailMattressReform[] @relation("MattressFeet")

  boxFeetSupply SaleItemDetailBoxReform[] @relation("BoxFeet")
  boxTapeSupply SaleItemDetailBoxReform[] @relation("BoxTape")

  newMattressFoamSupply SaleItemDetailNewMattress[] @relation("NewMattressFoam")
  newMattressTapeSupply SaleItemDetailNewMattress[] @relation("NewMattressTape")
  newMattressFeetSupply SaleItemDetailNewMattress[] @relation("NewMattressFeet")
  newBoxFeetSupply      SaleItemDetailNewBox[]      @relation("NewBoxFeet")
  newBoxTapeSupply      SaleItemDetailNewBox[]      @relation("NewBoxTape")

  @@index([name])
  @@index([categoryId])
  @@index([primarySupplierId])
  @@index([currentStock])
}

model StockMovement {
  id            String   @id @default(cuid())
  supplyItemId  String
  movementType  String
  quantity      Float
  unitCost      Float?
  totalCost     Float?
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime @default(now())

  supplyItem SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)

  @@index([supplyItemId])
  @@index([movementType])
  @@index([referenceType, referenceId])
  @@index([createdAt])
}

model Sale {
  id                    String   @id @default(cuid())
  number                String?  @unique
  customerId            String
  sellerId              String?
  leadSourceId          String
  cashRegisterSessionId String?
  saleDate              DateTime @default(now())
  subtotalAmount        Float    @default(0)
  discountAmount        Float    @default(0)
  surchargeAmount       Float    @default(0)
  totalAmount           Float    @default(0)
  paidAmount            Float    @default(0) // NEW: To track financial progress
  notes                 String?
  status                String   @default("CONFIRMED")
  financialStatus       String   @default("PENDING")

  // Lead Source Tracking
  leadSourceDetail   String?
  campaignName       String?
  referralName       String?
  externalSellerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  seller              Seller?              @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  leadSource          LeadSource           @relation(fields: [leadSourceId], references: [id], onDelete: Restrict)
  items               SaleItem[]
  installments        SaleInstallment[]
  commissions         CommissionEntry[]
  order               Order?
  cashRegisterSession CashRegisterSession? @relation(fields: [cashRegisterSessionId], references: [id], onDelete: SetNull)
  accountsReceivable  AccountReceivable[]

  cancelledAt   DateTime?
  cancelledById String?
  cancelledBy   User?     @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([sellerId])
  @@index([leadSourceId])
  @@index([cashRegisterSessionId])
  @@index([saleDate])
  @@index([status])
  @@index([financialStatus])
}

model SaleItem {
  id               String   @id @default(cuid())
  saleId           String
  productServiceId String?
  description      String
  quantity         Float    @default(1)
  unit             String?
  originalPrice    Float    @default(0)
  unitPrice        Float
  discountAmount   Float    @default(0)
  totalAmount      Float
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productService ProductService? @relation(fields: [productServiceId], references: [id], onDelete: SetNull)

  detailMattressReform     SaleItemDetailMattressReform?
  detailBoxReform          SaleItemDetailBoxReform?
  detailNewMattress        SaleItemDetailNewMattress?
  detailNewBox             SaleItemDetailNewBox?
  detailUpholsteryCleaning SaleItemDetailUpholsteryCleaning?

  materialRequirements SaleItemMaterialRequirement[]
  productionSlipLines  OrderProductionSlipLine[]

  @@index([saleId])
  @@index([productServiceId])
}

model SaleInstallment {
  id                String    @id @default(cuid())
  saleId            String
  paymentMethodId   String
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  paidAmount        Float     @default(0)
  paidAt            DateTime?
  status            String    @default("PENDING")
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sale              Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod      @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  accountReceivable AccountReceivable?

  @@unique([saleId, installmentNumber])
  @@index([paymentMethodId])
  @@index([dueDate])
  @@index([status])
}

model CommissionRule {
  id              String    @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean   @default(true)
  priority        Int       @default(0)
  calculationType String    @default("PERCENTAGE") // PERCENTAGE, FIXED, HYBRID
  baseType        String    @default("GROSS_SALE") // GROSS_SALE, NET_SALE, ITEM_BRUTO, ITEM_LIQUIDO, RECEIVED, PAID
  percentage      Float?
  fixedAmount     Float?
  validFrom       DateTime?
  validTo         DateTime?
  appliesOn       String    @default("CONFIRMED") // CONFIRMED, DELIVERED, PAID, FINALIZED
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conditions CommissionRuleCondition[]
  entries    CommissionEntry[]

  @@index([isActive, priority])
}

model CommissionRuleCondition {
  id               String   @id @default(cuid())
  commissionRuleId String
  conditionType    String // LEAD_SOURCE, PRODUCT_SERVICE, PRODUCT_CATEGORY, SERVICE_SUBTYPE, SELLER, GOAL_PERCENTAGE, MIN_SALE_AMOUNT, MAX_SALE_AMOUNT
  operator         String // EQUALS, IN, NOT_IN, GTE, LTE, BETWEEN
  value            String // JSON format for values or stringID
  createdAt        DateTime @default(now())

  rule CommissionRule @relation(fields: [commissionRuleId], references: [id], onDelete: Cascade)

  @@index([commissionRuleId])
}

model CommissionGoalPolicy {
  id               String   @id @default(cuid())
  name             String
  minGoalPercent   Float
